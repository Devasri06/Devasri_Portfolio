---
const aboutMe = {
  title: "About Me",
  subtitle: "Frontend Developer | UI/UX Enthusiast",
  description: `I specialize in crafting modern, aesthetic, and high-performance web applications. 
  With expertise in Astro.js, React, and Tailwind CSS, I create seamless user experiences that blend creativity and functionality. 
  My goal is to build intuitive interfaces that leave a lasting impact.`,
  skills: ["Frontend Development", "UI/UX Design", "Responsive Web Design", "Performance Optimization"],
};
---

<section class="py-16 bg-gray-900 text-white">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <h2 class="text-4xl font-bold text-purple-400">{{ aboutMe.title }}</h2>
    <p class="text-lg text-gray-300 mt-2">{{ aboutMe.subtitle }}</p>
    <p class="mt-6 text-gray-400 leading-relaxed">{{ aboutMe.description }}</p>
    
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      {aboutMe.skills.map((skill) => (
        <span class="bg-purple-600 text-white text-sm font-medium px-4 py-2 rounded-lg shadow-lg">
          {skill}
        </span>
      ))}
    </div>
  </div>
</section>
