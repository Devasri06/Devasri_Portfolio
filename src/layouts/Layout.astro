---
// src/layouts/Layout.astro
import { FaReact, FaHtml5, FaCss3, FaJs ,FaBootstrap } from 'react-icons/fa';
import { SiAstro, SiTailwindcss,SiCplusplus } from 'react-icons/si';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Devasri S P</title>
  </head>
  <body>
    <section class="min-h-screen flex flex-col justify-center items-center text-center bg-gradient-to-r from-gray-900 to-gray-600 text-white px-6">
      <h1 class="text-6xl font-extrabold mb-4 drop-shadow-lg">Devasri S P</h1>
      <p class="text-lg max-w-2xl bg-white/10 p-4 rounded-lg shadow-md">Highly organized individual eager to leverage skills in web development and cyber security.</p>
      <a href="#projects" class="mt-6 inline-block px-6 py-3 bg-yellow-400 text-black rounded-lg text-lg font-bold shadow-lg hover:bg-yellow-300 transition">View Projects</a>
    </section>
  
    <section id="about" class="py-20 bg-gray-800 text-white px-6 text-center">
      <h2 class="text-4xl font-bold mb-6 underline decoration-yellow-400">About Me</h2>
      <p class="max-w-3xl mx-auto text-lg p-4 italic">I am a passionate web developer and cyber security enthusiast, currently pursuing a Bachelor in Computer Science and Engineering with Cyber Security specialization.
         With experience in React, Astro.js, Bootstrap , HTML and Tailwind CSS, I love building interactive and visually appealing websites.</p>
    </section>
  
  
    <section class="py-12 bg-gray-800 text-white">
      <h2 class="text-3xl font-bold text-center">Skills & Technologies</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 p-6 text-center">
        
        <div class="flex flex-col items-center">
          <FaReact className="text-blue-500 text-6xl" />
          <p class="mt-2 text-lg">React.js</p>
        </div>
    
        <div class="flex flex-col items-center">
          <FaHtml5 className="text-orange-500 text-6xl" />
          <p class="mt-2 text-lg">HTML5</p>
        </div>
    
        <div class="flex flex-col items-center">
          <FaCss3 className="text-blue-400 text-6xl" />
          <p class="mt-2 text-lg">CSS</p>
        </div>
        <div class="flex flex-col items-center">
          <FaBootstrap className="text-blue-400 text-6xl" />
          <p class="mt-2 text-lg">BootStrap</p>
        </div>
        <div class="flex flex-col items-center">
          <SiCplusplus className="text-blue-400 text-6xl" />
          <p class="mt-2 text-lg">C++</p>
        </div>
    
    
        <div class="flex flex-col items-center">
          <SiTailwindcss className="text-teal-400 text-6xl" />
          <p class="mt-2 text-lg">Tailwind CSS</p>
        </div>
    
        <div class="flex flex-col items-center">
          <FaJs className="text-yellow-400 text-6xl" />
          <p class="mt-2 text-lg">JavaScript</p>
        </div>
    
        <div class="flex flex-col items-center">
          <SiAstro className="text-purple-400 text-6xl" />
          <p class="mt-2 text-lg">Astro.js</p>
        </div>
    
      </div>
    </section>
    
    <section id="projects" class="py-20 bg-gradient-to-r from-gray-800 to-gray-900 text-white p-6 text-center">
      <div class="">
      <h2 class="text-4xl font-bold mb-6 underline decoration-yellow-400">Projects</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="bg-gray-800 p-6 items-center justify-center rounded-lg shadow-lg hover:scale-105 transition">
          <h3 class="text-2xl font-bold mb-2 text-yellow-400">Sastika Solutions</h3>
          <p class="text-lg">A portfolio created for a trust company using Astro.js and Tailwind CSS.</p>
          <a href="https://sastika.eu" class="text-blue-400 underline hover:text-yellow-300 transition">sastika.eu</a>
        </div>
        <div class="bg-gray-800 p-6 rounded-lg shadow-lg hover:scale-105 transition">
          <h3 class="text-2xl font-bold mb-2 text-yellow-400">Franz-Kingstein</h3>
          <p class="text-lg">A simple portfolio created for a student using HTML and Bootstrap.</p>
          <a href="https://franzkingstein.site" class="text-blue-400 underline hover:text-yellow-300 transition">franzkingstein</a>
        </div>
      </div>
    </div>
    </section>
  
    <section id="contact" class="py-20 bg-gray-900 text-white px-6 text-center">
      <h2 class="text-4xl font-bold mb-6 underline decoration-yellow-400">Contact</h2>
      <p class="text-lg bg-white/10 p-4 rounded-lg shadow-md">Feel free to reach out to me via email or phone.</p>
      <p class="mt-4 text-lg"> 
        <a href="mailto:contact@devasri.com" class="text-yellow-400 hover:text-yellow-300 transition">
          
          contact@devasri.com</a>
        </p>
      <p class="text-lg"> <a href="tel:+918248062614" class="text-yellow-400 hover:text-yellow-300 transition">+91 8248062614</a></p>
    </section>
  </body>
</html>