---
// NavBar.astro
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  {

  }
];

const socialLinks = [
  {
    name: "Instagram",
    icon: "/icons/instagram.svg",
    url: "#",
  },
  {
    name: "Twitter",
    icon: "/icons/twitter.svg",
    url: "#",
  },
  {
    name: "Facebook",
    icon: "/icons/facebook.svg",
    url: "#",
  },
  {
    name: "WhatsApp",
    icon: "/icons/whatsapp.svg",
    url: "#",
  },
];
---

<nav class="fixed top-0 w-full bg-gray-700 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      
      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        {
         
        }
      </div>

      <!-- Social Icons - Desktop -->
      <div class="hidden md:flex items-center space-x-4">
        {
          socialLinks.map(({ name, icon, url }) => (
            <a
              href={url}
              class="text-gray-500 hover:text-red-600 transition-colors duration-200"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="sr-only">{name}</span>
              <img
                src={icon}
                alt={name}
                class="w-5 h-5 object-contain"
                width="20"
                height="20"
              />
            </a>
          ))
        }
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button
          id="mobile-menu-button"
          class="text-gray-500 hover:text-red-600 focus:outline-none"
        >
          <span class="sr-only">Open main menu</span>
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
    <div class="px-2 pt-2 pb-3 space-y-1">
      {
        
      }
    </div>
    <div
      class="px-5 py-3 border-t border-gray-200 flex justify-center space-x-6"
    >
      {
        socialLinks.map(({ name, icon, url }) => (
          <a
            href={url}
            class="text-gray-500 hover:text-red-600"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="sr-only">{name}</span>
            <img
              src={icon}
              alt={name}
              class="w-5 h-5 object-contain"
              width="20"
              height="20"
            />
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script>
  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");

  mobileMenuButton?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });
</script>
